<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- ID Hóa đơn -->
            <TextView
                android:id="@+id/tv_item_invoice_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DL0123"
                android:textColor="#185FA5"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Trạng thái -->
            <TextView
                android:id="@+id/tv_item_invoice_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#E8F5E9"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Đã thanh toán"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_item_invoice_tour_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tour Miền Trung 4N3Đ: HCM - Đà Nẵng - Hội An..."
            android:textColor="#2D3748"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EDF2F7"
            android:layout_marginVertical="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_item_invoice_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày khởi hành: 09/09"
                    android:textColor="#718096"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_item_invoice_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.490.000đ"
                android:textColor="#185FA5"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
