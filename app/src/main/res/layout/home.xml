<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/nenanh" />

    <!-- Scrollable content to prevent layout clipping -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="0dp">

            <!-- Logo Chill Tour -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/avatar_moi" />

            <!-- Search Card Container -->
            <LinearLayout
                android:id="@+id/layoutSearchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header Title -->
                <TextView
                    android:id="@+id/tvSearchHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hơn 1000+ Tour, Khám Phá Ngay"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Field 1: Destination -->
                <LinearLayout
                    android:id="@+id/layoutDestination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_location_pin" />

                    <EditText
                        android:id="@+id/etDestination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="Bạn muốn đi đâu?"
                        android:textColorHint="#888888"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:focusable="false"
                        android:clickable="true" />
                </LinearLayout>

                <!-- Field 2: Departure Date -->
                <LinearLayout
                    android:id="@+id/layoutDepartureDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_calendar" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngày khởi hành"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvDepartureDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="23 tháng 05"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Field 3: Origin City -->
                <LinearLayout
                    android:id="@+id/layoutOriginCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_trip"
                        app:tint="#888888" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khởi hành từ"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvOriginCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hồ Chí Minh"
                            android:textColor="#333333"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Find Tour Button -->
                <TextView
                    android:id="@+id/btnFindTour"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_search_button"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="Tìm tour"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Voucher Section -->
            <LinearLayout
                android:id="@+id/layoutVoucherSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F8FAFC"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnAllVouchers"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Voucher Ưu Đãi Cực Hot"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lưu voucher ngay, nhận ngàn ưu đãi"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnAllVouchers"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_list"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Vouchers -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHomeVouchers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Tour Discount Section -->
            <LinearLayout
                android:id="@+id/layoutTourSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF9F1"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnMoreTours"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tour Ưu Đãi Tốt Nhất Hôm Nay"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhanh Tay Đặt Ngay. Để Mai Sẽ Lỡ"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnMoreTours"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Tour Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTourUuDai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Recommendation Section (Gợi ý cho bạn) -->
            <LinearLayout
                android:id="@+id/layoutRecommendationSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F0FDFA"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnMoreRecommendTours"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gợi ý cho bạn"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Những Tour Được Quan Tâm &amp; Xem Nhiều Nhất"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnMoreRecommendTours"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Recommendations -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTourRecommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Tour Miền Bắc Section -->
            <LinearLayout
                android:id="@+id/layoutNorthernTourSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F8FC"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnMoreNorthernTours"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tour Du Lịch Miền Bắc"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khám Phá Vẻ Đẹp Kỳ Vĩ Của Núi Rừng &amp; Kỳ Quan"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnMoreNorthernTours"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Tour Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTourMienBac"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Tour Miền Trung Section -->
            <LinearLayout
                android:id="@+id/layoutCentralTourSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFBF4"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnMoreCentralTours"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tour Du Lịch Miền Trung"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Di Sản Văn Hóa, Biển Xanh &amp; Cát Trắng Nắng Vàng"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnMoreCentralTours"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Tour Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTourMienTrung"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Tour Miền Nam Section -->
            <LinearLayout
                android:id="@+id/layoutSouthernTourSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FAF8F5"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Header Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnMoreSouthernTours"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tour Du Lịch Miền Nam"
                            android:textColor="#333333"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thiên Đường Sông Nước &amp; Biển Đảo Quyến Rũ"
                            android:textColor="#777777"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnMoreSouthernTours"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_cyan"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Horizontal Scroll View for Tour Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTourMienNam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
