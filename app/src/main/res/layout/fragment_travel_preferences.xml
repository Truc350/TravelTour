<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Toolbar Header -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back Button"
            android:padding="12dp"
            app:tint="#333333" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Sở thích du lịch"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Hạng sao yêu thích -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hạng sao yêu thích"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutStars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">

                <TextView
                    android:id="@+id/btnStar1"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:gravity="center"
                    android:text="1 ★"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnStar2"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:gravity="center"
                    android:text="2 ★"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnStar3"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:gravity="center"
                    android:text="3 ★"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnStar4"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:gravity="center"
                    android:text="4 ★"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnStar5"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:gravity="center"
                    android:text="5 ★"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Section 2: Phong cách yêu thích -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phong cách yêu thích"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <com.example.myapplication.utils.FlowLayout
                android:id="@+id/flowStyles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Hiện đại"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Gần gũi với thiên nhiên"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Đông dương"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Tiện lợi"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Sống ảo"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.example.myapplication.utils.FlowLayout>

            <!-- Section 3: Thương hiệu Yêu Thích -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thương hiệu Yêu Thích"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <com.example.myapplication.utils.FlowLayout
                android:id="@+id/flowBrands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="The Grand"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Intercontinental"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Vinpearl"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="The Anam"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Novotel"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Sheraton"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.example.myapplication.utils.FlowLayout>

            <!-- Section 4: Loại hình nơi ở -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại hình nơi ở"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <com.example.myapplication.utils.FlowLayout
                android:id="@+id/flowAccommodations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Khu nghỉ dưỡng (Resort)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Biệt thự (Villa)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Khách sạn (hotel)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Căn hộ (Apartment)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Du thuyền (Cruise)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Nhà nghỉ (Guest house, homestay)"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.example.myapplication.utils.FlowLayout>

            <!-- Section 5: Tiện ích -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiện ích"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <com.example.myapplication.utils.FlowLayout
                android:id="@+id/flowAmenities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Phòng gia đình"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Bãi biển riêng"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Bãi đậu xe ô tô tại khách sạn"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_pref_unselected"
                    android:textColor="#4A5568"
                    android:text="Hồ bơi"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </com.example.myapplication.utils.FlowLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
