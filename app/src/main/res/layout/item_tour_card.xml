<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Image & Service Badge -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <ImageView
                android:id="@+id/ivTourImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_phuquoc_tour"
                android:contentDescription="Tour Image" />

            <!-- Service Badge (e.g. "Vietjet Air") -->
            <TextView
                android:id="@+id/tvRibbonBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vietjet Air"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_red"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="12dp" />
        </FrameLayout>

        <!-- Details Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Dynamic Tour Title -->
            <TextView
                android:id="@+id/tvTourTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tour Phú Quốc 3N2Đ: HCM - Phú Quốc - Câu Cá Lặn Ngắm San Hô - Nam Đảo"
                android:textColor="#2D3748"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="3sp"
                android:layout_marginBottom="16dp" />

            <!-- Price & Button Layout -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Left: Price Info -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/tvOldPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.290.000"
                        android:textColor="#A0AEC0"
                        android:textSize="13sp"
                        android:background="@drawable/bg_badge_pink"
                        android:paddingHorizontal="4dp"
                        android:layout_marginBottom="2dp" />

                    <!-- Strikethrough is applied in Java to tvOldPrice, or using flags -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tvNewPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.990.000"
                            android:textColor="#FF9F1C"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCurrency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VND"
                            android:textColor="#FF9F1C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="2dp"
                            android:layout_marginBottom="2dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Right: Action Button -->
                <TextView
                    android:id="@+id/btnViewTour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_search_button"
                    android:text="Xem tour"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
