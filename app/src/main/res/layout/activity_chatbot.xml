<?xml version="1.0" encoding="utf-8"?>
<!-- Giao diện Chatbot chăm sóc khách hàng ChillTour -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E6F1FB">

    <!-- ========== HEADER ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#185FA5"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Nút quay lại -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp" />

            <!-- Avatar bot -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="#2979C7"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chatbot"
                        android:tint="#FFFFFF" />
                </androidx.cardview.widget.CardView>

                <!-- Chấm xanh Online -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_unread_dot" />
            </FrameLayout>

            <!-- Tên & trạng thái bot -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ChillBot"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hỗ trợ 24/7 · Đang hoạt động"
                    android:textColor="#B3D9FF"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ========== CHAT LIST ========== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- ========== QUICK REPLY CHIPS ========== -->
    <HorizontalScrollView
        android:id="@+id/scrollQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:background="#E6F1FB">

        <LinearLayout
            android:id="@+id/layoutQuickReplies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </HorizontalScrollView>

    <!-- ========== INPUT BAR ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:hint="Nhập câu hỏi của bạn..."
            android:textColorHint="#AAAAAA"
            android:textColor="#222222"
            android:textSize="15sp"
            android:background="@drawable/bg_search_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:imeOptions="actionSend"
            android:layout_marginEnd="10dp" />

        <!-- Nút gửi -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_trip"
            android:tint="#FFFFFF"
            android:padding="10dp"
            android:background="@drawable/bg_search_button"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
