<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardHomeVoucher"
    android:layout_width="260dp"
    android:layout_height="125dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left block for discount value -->
        <LinearLayout
            android:id="@+id/layoutLeftBlock"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="#319795"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_voucher"
                app:tint="#FFFFFF"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvDiscountVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15%"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDiscountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOUCHER"
                android:textColor="#E2E8F0"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Ticket cut dashed line effect using a thin divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E2E8F0" />

        <!-- Right block for details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvVoucherTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voucher Title"
                android:textColor="#2D3748"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Status and Remaining Count Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvVoucherStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn hiệu lực"
                    android:textColor="#2B6CB0"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="1dp" />

                <TextView
                    android:id="@+id/tvVoucherRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Còn 120 lượt"
                    android:textColor="#718096"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Expiry date -->
            <TextView
                android:id="@+id/tvVoucherExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="HSD: 31/08/2026"
                android:textColor="#E53E3E"
                android:textSize="10sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Save Button Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSaveVoucher"
                    android:layout_width="85dp"
                    android:layout_height="25dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_pref_selected"
                    android:text="Lưu vào kho"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:padding="0dp" />
            </RelativeLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
