<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F1FB"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:text="Yêu thích"
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Container for List or Empty State -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="visible">

            <ImageView
                android:id="@+id/imgEmpty"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/ic_empty_travel"
                android:contentDescription="Empty favorite list" />

            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Không có tour yêu thích!"
                android:textColor="#777777"
                android:textSize="16sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Scrollable Favorite List -->
        <ScrollView
            android:id="@+id/scrollViewFavoriteList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/favoriteContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="24dp" />
        </ScrollView>
    </FrameLayout>

</LinearLayout>