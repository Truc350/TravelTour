<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ticket Header (Cyan Gradient Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#185FA5"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VÉ TOUR DU LỊCH ĐIỆN TỬ"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvDlgHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chuyến đi sắp tới"
                android:textColor="#E3F2FD"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Train Info -->
            <TextView
                android:id="@+id/tvDlgTrainName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tàu hoa phượng đỏ - HP1"
                android:textColor="#2D3748"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Route Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Dep -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/tvDlgDepTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="06:00"
                        android:textColor="#1A202C"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDlgDepStation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ga Hà Nội"
                        android:textColor="#718096"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Arrow -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDlgDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2g25p"
                        android:textColor="#718096"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="──────►"
                        android:textColor="#CBD5E0"
                        android:textSize="11sp"
                        android:layout_marginTop="-2dp"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <!-- Arr -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvDlgArrTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:25"
                        android:textColor="#1A202C"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDlgArrStation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ga Hải Phòng"
                        android:textColor="#718096"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Date & Seat Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#F8F9FA"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày đi"
                        android:textColor="#718096"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvDlgDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09/09/2026"
                        android:textColor="#2D3748"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toa / Số ghế"
                        android:textColor="#718096"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvDlgSeat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toa 4 / Ghế 23"
                        android:textColor="#2D3748"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Ticket Price -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Tổng thanh toán:"
                    android:textColor="#2D3748"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvDlgPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="109.000 đ"
                    android:textColor="#185FA5"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Barcode Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <ImageView
                    android:id="@+id/imgDlgQrCode"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_qr_code"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/tvDlgTicketCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.15"
                    android:text="TKT-2026-0909-001"
                    android:textColor="#2D3748"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quét mã QR/nhấn để xem chi tiết Tour"
                    android:textColor="#A0AEC0"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDlgViewTour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_orange"
                    android:text="XEM CHI TIẾT TOUR"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDlgAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_chip_selected_cyan"
                    android:text="XÁC NHẬN CHUYẾN ĐI THÀNH CÔNG"
                    android:textColor="#00B4D8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
