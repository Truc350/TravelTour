<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVoucher"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="Intrinsic"
        android:minHeight="100dp"
        android:orientation="horizontal">

        <!-- Left Block: Discount display -->
        <LinearLayout
            android:id="@+id/layoutLeftBlock"
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:background="@color/cyan_active"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_voucher"
                app:tint="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvDiscountVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10%"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDiscountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIẢM GIÁ"
                android:textColor="#E2E8F0"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider Line -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E2E8F0" />

        <!-- Right Block: Info and actions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvVoucherTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giảm 10% Tour Hè Rực Rỡ"
                android:textColor="#2D3748"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Giảm tối đa 200k cho các tour Đà Nẵng, Phú Quốc, Nha Trang."
                android:textColor="#718096"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvVoucherExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="HSD: 30/09/2026"
                android:textColor="#E53E3E"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Code Container -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp">

                    <TextView
                        android:id="@+id/tvVoucherCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHILLTOUR10"
                        android:textColor="#185FA5"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Action Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnVoucherAction"
                    android:layout_width="72dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_pref_selected"
                    android:text="Sao chép"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
