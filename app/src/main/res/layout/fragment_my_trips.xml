<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7FAFC">

    <!-- Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#2D3748" />

        <!-- Title & Subtitle Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <!-- Title -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chuyến đi của bạn"
                    android:textColor="#2D3748"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_chevron_down"
                    android:layout_marginStart="4dp"
                    app:tint="#2D3748"
                    android:contentDescription="Dropdown" />
            </LinearLayout>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ga Hà Nội ➔ Ga Hải Phòng"
                android:textColor="#718096"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Right Side balancing view -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- Custom Premium Tab Toggle (Upcoming vs History) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="1dp">

        <!-- Tab 1: Sắp tới -->
        <LinearLayout
            android:id="@+id/tabUpcoming"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvTabUpcomingText"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Sắp tới"
                android:textColor="#185FA5"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/tabUpcomingIndicator"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#185FA5"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Tab 2: Lịch sử -->
        <LinearLayout
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvTabHistoryText"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Lịch sử"
                android:textColor="#718096"
                android:textSize="15sp" />

            <View
                android:id="@+id/tabHistoryIndicator"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#185FA5"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Date selector Ribbon (Visible in "Sắp tới" Tab) -->
    <FrameLayout
        android:id="@+id/layoutDateRibbonContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF">

        <HorizontalScrollView
            android:id="@+id/hsvDateRibbon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutDateTabsContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- Bottom divider line for ribbon -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <!-- Content Listing Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Recycler View of Trip Tickets -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTickets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="8dp"
            android:clipToPadding="false" />

        <!-- Empty State View -->
        <LinearLayout
            android:id="@+id/layoutNoTrips"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_empty_travel"
                android:alpha="0.6"
                app:tint="#A0AEC0"
                android:contentDescription="No Trips" />

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không tìm thấy chuyến đi nào"
                android:textColor="#718096"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvEmptySubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn chưa đặt chuyến đi nào trong thời gian này."
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
