<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ===== TOOLBAR ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_left_dark"
            android:contentDescription="Quay lại"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Lịch khởi hành và giá"
            android:textColor="#212529"
            android:textSize="17sp"
            android:textStyle="bold" />


        <!-- Divider bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E9ECEF"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tên tour -->
            <TextView
                android:id="@+id/tv_tour_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tour Phú Quốc 3N2Đ: HCM - Phú Quốc - Câu Cá Lặn Ngắm San Hô - Nam Đảo"
                android:textColor="#1565C0"
                android:textSize="17sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <!-- Chọn ngày khởi hành -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn ngày khởi hành:"
                android:textColor="#212529"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <!-- Date chips row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:id="@+id/layout_date_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                </LinearLayout>
            </HorizontalScrollView>
            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa chọn ngày khởi hành"
                android:textColor="#999999"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />
            <!-- Chọn giờ khởi hành -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giờ khởi hành:"
                android:textColor="#212529"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:id="@+id/layout_time_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E9ECEF"
                android:layout_marginBottom="4dp" />

            <!-- ===== Người lớn ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp">

                <!-- Label -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Người lớn"
                        android:textColor="#212529"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Từ 10 tuổi"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Đơn giá -->
                <TextView
                    android:id="@+id/tv_adult_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="x 5.490.000"
                    android:textColor="#6C757D"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <!-- Nút trừ -->
                <TextView
                    android:id="@+id/btn_adult_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Số lượng -->
                <TextView
                    android:id="@+id/tv_adult_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#212529"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Nút cộng -->
                <TextView
                    android:id="@+id/btn_adult_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E9ECEF" />

            <!-- ===== Trẻ em ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trẻ em"
                        android:textColor="#212529"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 - 9 tuổi"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_child_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="x 0đ"
                    android:textColor="#6C757D"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/btn_child_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn_disabled"
                    android:alpha="0.45"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_child_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#212529"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/btn_child_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E9ECEF" />

            <!-- ===== Trẻ nhỏ ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trẻ nhỏ"
                        android:textColor="#212529"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&lt; 5 tuổi"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_infant_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Miễn phí"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/btn_infant_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_infant_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#212529"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/btn_infant_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_count_btn"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E9ECEF"
                android:layout_marginBottom="14dp" />

            <!-- Chọn voucher row -->
            <LinearLayout
                android:id="@+id/row_promo_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_voucher_row"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="12dp">

                <!-- Ticket Icon -->
                <ImageView
                    android:id="@+id/iv_voucher_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_voucher"
                    app:tint="#185FA5"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Voucher" />

                <TextView
                    android:id="@+id/tv_voucher_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chọn voucher"
                    android:textColor="#185FA5"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_clear_voucher"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_close"
                    app:tint="#E53935"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Bỏ chọn"
                    android:layout_marginEnd="2dp" />

                <ImageView
                    android:id="@+id/iv_chevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#185FA5"
                    android:contentDescription="Chevron" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E9ECEF"
                android:layout_marginBottom="14dp" />

            <!-- Còn nhận chỗ -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="14sp"
                    android:textColor="#E53935" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="13sp"
                    android:textColor="#E53935">
                    <![CDATA[]]>
                </TextView>

                <!-- Dùng SpannableString trong code, tạm set text tĩnh -->
                <TextView
                    android:id="@+id/tv_seats_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Còn nhận 14 chỗ"
                    android:textSize="13sp"
                    android:textColor="#E53935"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Tổng cộng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tổng cộng"
                    android:textColor="#212529"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_total_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10.980.000đ"
                    android:textColor="#00ACC1"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM BUTTON BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="12dp">

        <!-- Nút Đặt tour ngay -->
        <Button
            android:id="@+id/btn_book"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_orange"
            android:text="Đặt tour ngay"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
