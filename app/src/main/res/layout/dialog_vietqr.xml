<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#185FA5"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THANH TOÁN QUA VIETQR"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quét mã QR để hoàn tất đơn hàng"
                android:textColor="#E3F2FD"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Instruction -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dùng ứng dụng ngân hàng quét mã dưới đây để chuyển khoản nhanh 24/7."
                    android:textColor="#718096"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- QR Frame -->
                <FrameLayout
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_payment_card_border"
                    android:padding="4dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/img_vietqr_code"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:contentDescription="Mã QR VietQR" />

                    <ProgressBar
                        android:id="@+id/pb_qr_loading"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#185FA5" />
                </FrameLayout>

                <!-- Status / Auto timer text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <ProgressBar
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:indeterminateTint="#FFA726" />

                    <TextView
                        android:id="@+id/tv_payment_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang chờ quét mã... (60s)"
                        android:textColor="#E65100"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginBottom="16dp" />

                <!-- Transfer Info Rows -->
                <!-- Bank Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Ngân hàng"
                        android:textColor="#718096"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MB Bank (Ngân hàng Quân Đội)"
                        android:textColor="#1A202C"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Account Number Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Số tài khoản"
                        android:textColor="#718096"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tv_qr_account_no"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="113366668888"
                        android:textColor="#1A202C"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btn_copy_account_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sao chép"
                        android:textColor="#00B4D8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected_cyan"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Account Name Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Chủ tài khoản"
                        android:textColor="#718096"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tv_qr_account_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LAM DAI"
                        android:textColor="#1A202C"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btn_copy_account_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sao chép"
                        android:textColor="#00B4D8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected_cyan"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Amount Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Số tiền"
                        android:textColor="#718096"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tv_qr_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10.980.000 đ"
                        android:textColor="#FF8F00"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btn_copy_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sao chép"
                        android:textColor="#00B4D8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected_cyan"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Transfer Info Code Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Nội dung"
                        android:textColor="#718096"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tv_qr_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Thanh toan tour DL0091642"
                        android:textColor="#1A202C"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btn_copy_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sao chép"
                        android:textColor="#00B4D8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected_cyan"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Action Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_qr_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_orange"
                    android:text="TÔI ĐÃ CHUYỂN KHOẢN XONG"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.cardview.widget.CardView>
