<?xml version="1.0" encoding="utf-8"?>
<!--
    Bộ chọn màu cho biểu tượng và chữ trên thanh điều hướng.
    - Khi tab được chọn (state_checked = true): dùng màu xanh đậm (colorActive)
    - Khi tab chưa được chọn: dùng màu xám (colorInactive)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Tab đang được chọn -->
    <item android:state_checked="true" android:color="@color/colorActive" />
    <!-- Tab chưa được chọn -->
    <item android:color="@color/colorInactive" />
</selector>
